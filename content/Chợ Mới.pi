CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- 2. Bảng Tỉnh Thành / Quận Huyện (Locations)
CREATE TABLE locations (
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    parent_id INTEGER REFERENCES locations(id), -- Để tạo quan hệ Tỉnh -> Quận -> Phường
    type VARCHAR(50), -- 'province', 'district', 'ward'
    slug VARCHAR(255)
);

-- 3. Bảng Danh mục (Categories)
CREATE TABLE categories (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    parent_id INTEGER REFERENCES categories(id),
    slug VARCHAR(100) UNIQUE NOT NULL,
    icon_url TEXT
);

-- 4. Bảng Người dùng (Users)
CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    phone_number VARCHAR(20) UNIQUE NOT NULL,
    full_name VARCHAR(100),
    password_hash TEXT NOT NULL,
    avatar_url TEXT,
    is_verified BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 5. Bảng Tin đăng (Posts) - Trái tim của ứng dụng
CREATE TABLE posts (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,
    category_id INTEGER REFERENCES categories(id),
    location_id INTEGER REFERENCES locations(id),
    
    title VARCHAR(255) NOT NULL,
    description TEXT,
    price BIGINT DEFAULT 0,
-- Cột JSONB chứa các thuộc tính động (Ví dụ: số km, số phòng ngủ, hãng xe...)

    attributes JSONB DEFAULT '{}',

    

    status VARCHAR(20) DEFAULT 'pending', -- pending, active, sold, hidden

    is_vip BOOLEAN DEFAULT FALSE,

    

    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,

    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP

);


-- 6. Bảng Hình ảnh (Post Images)

CREATE TABLE post_images (

    id SERIAL PRIMARY KEY,

    post_id UUID REFERENCES posts(id) ON DELETE CASCADE,

    image_url TEXT NOT NULL,

    is_feature BOOLEAN DEFAULT FALSE -- Ảnh đại diện cho tin đăng
);
CREATE INDEX idx_posts_category ON posts(category_id);

CREATE INDEX idx_posts_location ON posts(location_id);

CREATE INDEX idx_posts_attributes ON posts USING GIN (attributes); -- Index chuyên dụng cho JSONB

