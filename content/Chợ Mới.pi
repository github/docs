Javascript 

const express = require('express');

const pool = require('./db');

const app = express();


app.get('/api/posts/search', async (req, res) => {

    try {

        const { 

            q,              // Từ khóa tìm kiếm (title)

            category_id, 

            location_id, 

            price_min, 

            price_max, 

            brand,          // Ví dụ lọc theo hãng (trong JSONB)

            sort_by,        // 'price_asc', 'price_desc', 'newest'

            page = 1        // Phân trang

        } = req.query;


        const limit = 20; // Mỗi trang 20 tin

        const offset = (page - 1) * limit;


        let queryText = `

            SELECT p.*, i.image_url as thumbnail 

            FROM posts p

            LEFT JOIN post_images i ON p.id = i.post_id AND i.is_feature = true

            WHERE p.status = 'active'

        `;

        

        const values = [];

        let count = 1;


        // 1. Lọc theo từ khóa (Search by Title)

        if (q) {

            queryText += ` AND p.title ILIKE $${count}`;

            values.push(`%${q}%`);

            count++;

        }


        // 2. Lọc theo danh mục

        if (category_id) {

            queryText += ` AND p.category_id = $${count}`;

            values.push(category_id);

            count++;

        }


        // 3. Lọc theo khoảng giá

        if (price_min) {

            queryText += ` AND p.price >= $${count}`;

            values.push(price_min);

            count++;

        }

        if (price_max) {

            queryText += ` AND p.price <= $${count}`;

            values.push(price_max);

            count++;

        }


        // 4. Lọc sâu vào JSONB (Ví dụ lọc theo Hãng xe)

        if (brand) {

            queryText += ` AND p.attributes->>'hang_xe' = $${count}`;

            values.push(brand);

            count++;

        }


        // 5. Sắp xếp

        if (sort_by === 'price_asc') {

            queryText += ` ORDER BY p.price ASC`;

        } else if (sort_by === 'price_desc') {

            queryText += ` ORDER BY p.price DESC`;

        } else {

            queryText += ` ORDER BY p.created_at DESC`;

        }


        // 6. Phân trang

        queryText += ` LIMIT ${limit} OFFSET ${offset}`;


        const result = await pool.query(queryText, values);

        

        res.json({

            page: parseInt(page),

            count: result.rowCount,

            data: result.rows

        });


    } catch (err) {

        console.error(err);

        res.status(500).send("Lỗi truy vấn tìm kiếm");

    }

});GET /api/posts/search?category_id=1&brand=Honda&price_max=20000000
