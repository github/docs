CREATE TABLE conversations (

    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),

    post_id UUID REFERENCES posts(id),

    buyer_id UUID REFERENCES users(id),

    seller_id UUID REFERENCES users(id),

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    UNIQUE(post_id, buyer_id, seller_id) -- Một món hàng chỉ có 1 luồng chat giữa 2 người cụ thể

);CREATE TABLE messages (
    id SERIAL PRIMARY KEY,

    conversation_id UUID REFERENCES conversations(id) ON DELETE CASCADE,

    sender_id UUID REFERENCES users(id),

    message_text TEXT NOT NULL,

    is_read BOOLEAN DEFAULT FALSE,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP

);WebSocket.
const express = require('express');
const http = require('http');
const { Server } = require('socket.io');
const pool = require('./db');

const app = express();
const server = http.createServer(app);
const io = new Server(server, {
    cors: { origin: "*" } // Cho phép mọi nguồn kết nối (trong thực tế nên giới hạn)
});

// Quản lý các user đang online
const onlineUsers = new Map(); // userId => socketId

io.on('connection', (socket) => {
    console.log('Một người dùng vừa kết nối:', socket.id);
// 1. Khi User login vào app, họ sẽ "đăng ký" socketId

    socket.on('register', (userId) => {

        onlineUsers.set(userId, socket.id);

        console.log(`User ${userId} đang online`);

    });


    // 2. Xử lý gửi tin nhắn

    socket.on('send_message', async (data) => {

        const { conversation_id, sender_id, receiver_id, message_text } = data;


        try {

            // Lưu tin nhắn vào Database trước

            const res = await pool.query(

                'INSERT INTO messages (conversation_id, sender_id, message_text) VALUES (pi1, pi2, pi3) RETURNING *',

                [conversation_id, sender_id, message_text]

            );

            const newMessage = res.rows[0];


            // Nếu người nhận đang online, gửi tin nhắn trực tiếp qua Socket

            const receiverSocketId = onlineUsers.get(receiver_id);

            if (receiverSocketId) {

                io.to(receiverSocketId).emit('receive_message', newMessage);

            }

            

            // Phản hồi lại cho người gửi là đã lưu thành công

            socket.emit('message_sent', newMessage);


        } catch (err) {

            console.error('Lỗi lưu tin nhắn:', err);

        }

    });


    socket.on('disconnect', () => {

        // Xóa user khỏi danh sách online khi họ thoát

        for (let [userId, socketId] of onlineUsers.entries()) {

            if (socketId === socket.id) {

                onlineUsers.delete(userId);

                break;

            }

        }

    });

});


server.listen(3001, () => console.log('Chat Server chạy tại port 3001'));

Client là cách ứng dụng (Web hoặc Mobile) kết nối và nhận tin nhắn.

const socket = io("http://localhost:3001");


// 1. Đăng ký khi mở app

const myUserId = "ID_CUA_BAN";

socket.emit('register', myUserId);


// 2. Gửi tin nhắn khi bấm nút "Gửi"

function sendMessage(text, receiverId, convId) {

    socket.emit('send_message', {

        conversation_id: convId,

        sender_id: myUserId,

        receiver_id: receiverId,

        message_text: text

    });

}


// 3. Lắng nghe tin nhắn mới đến

socket.on('receive_message', (message) => {

    console.log("Bạn có tin nhắn mới:", message.message_text);

    // Hiển thị tin nhắn lên giao diện chat

});
