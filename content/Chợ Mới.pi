Javascript

const express = require('express');

const pool = require('./db');

const app = express();


app.use(express.json());


// API: Đăng tin rao vặt mới

app.post('/api/posts', async (req, res) => {

    const { 

        user_id, 

        category_id, 

        location_id, 

        title, 

        description, 

        price, 

        attributes, // Đối tượng JSON chứa đặc điểm riêng (vd: { "hang_xe": "Honda" })

        images      // Mảng các đường dẫn ảnh (vd: ["url1", "url2"])

    } = req.body;


    try {

        // 1. Bắt đầu một Transaction (đảm bảo đăng tin và lưu ảnh phải cùng thành công)

        const client = await pool.connect();

        try {

            await client.query('BEGIN');


            // 2. Chèn dữ liệu vào bảng posts

            const postQuery = `

                INSERT INTO posts (user_id, category_id, location_id, title, description, price, attributes)

                VALUES (pi1, pi2, pi3, pi4, pi5, pi6, pi7)

                RETURNING id;

            `;

            const postValues = [user_id, category_id, location_id, title, description, price, attributes];

            const postResult = await client.query(postQuery, postValues);

            const postId = postResult.rows[0].id;


            // 3. Chèn danh sách ảnh vào bảng post_images

            if (images && images.length > 0) {

                const imageQueries = images.map((url, index) => {

                    return client.query(

                        'INSERT INTO post_images (post_id, image_url, is_feature) VALUES (pi1, pi2, pi3)',

                        [postId, url, index === 0] // Ảnh đầu tiên mặc định là ảnh đại diện

                    );

                });

                await Promise.all(imageQueries);

            }


            await client.query('COMMIT');

            res.status(201).json({ message: "Đăng tin thành công!", post_id: postId });


        } catch (error) {

            await client.query('ROLLBACK'); // Nếu lỗi thì hủy toàn bộ thao tác trên

            throw error;

        } finally {

            client.release();

        }

    } catch (err) {

        console.error(err);

        res.status(500).json({ error: "Lỗi hệ thống khi đăng tin." });

    }

});


const PORT = 3000;

app.listen(PORT, () => console.log(`Server chạy tại port pi{PORT}`));
