                43
              ],
              [
                0,
                2,
                21
              ]
            ],
            "schema": {
              "type": "array",
              "items": {
                "title": "Code Frequency Stat",
                "description": "Code Frequency Stat",
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            }
          }
        }
      ],
      "statusCodes": [
