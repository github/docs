      "verb": "get",
      "requestPath": "/repos/{owner}/{repo}/stats/punch_card",
      "title": "Get the hourly commit count for each day",
      "category": "metrics",
      "subcategory": "statistics",
      "parameters": [
        {
          "name": "owner",
          "description": "<p>The account owner of the repository. The name is not case sensitive.</p>",
          "in": "path",
          "required": true,
